<?xml version="1.0" encoding="utf-8"?>
<ModMetaData>
  <name>Precision Stockpile Control</name>
  <author>CheaterEater</author>
  <packageId>CheaterEater.PrecisionStockpileControl</packageId>
  <supportedVersions>
    <li>1.6</li>
  </supportedVersions>
  <description>Set exact per-storage limits, refill thresholds, and hauling batch sizes. Route items from one storage into another, fine-tune priority, or switch a storage to fill-only / drain-only / frozen. Stockpiles you don't configure behave exactly like vanilla.</description>
  <modVersion>0.1.0</modVersion>
  <url>https://github.com/CheaterEater-RM/Precision-Stockpile-Control</url>

  <modDependencies>
    <li>
      <packageId>brrainz.harmony</packageId>
      <displayName>Harmony</displayName>
      <steamWorkshopUrl>steam://url/CommunityFilePage/2009463077</steamWorkshopUrl>
    </li>
  </modDependencies>

  <loadAfter>
    <li>brrainz.harmony</li>
    <li>Ludeon.RimWorld</li>
    <li>Ludeon.RimWorld.Royalty</li>
    <li>Ludeon.RimWorld.Ideology</li>
    <li>Ludeon.RimWorld.Biotech</li>
    <li>Ludeon.RimWorld.Anomaly</li>
    <li>Ludeon.RimWorld.Odyssey</li>
  </loadAfter>

  <!-- Other stockpile-limit mods set the same per-storage caps/refill PSC does, so running them
       alongside PSC double-enforces. PSC subsumes their function and imports their leftover limits
       once they're removed (see PscMigration). This is a soft warning, not a hard block. Storage
       Sorting, OgreStack, and LWM Deep Storage are a different axis and stay compatible. Flickable
       Storage stays compatible too, but PSC's storage modes now subsume it (running both just
       duplicates the mode gizmo) — not listed as incompatible because it doesn't double-enforce. -->
  <incompatibleWith>
    <li>Andromeda.StackGap</li>                  <!-- Stack Gap -->
    <li>ryder.SatisfiedStorage</li>              <!-- Satisfied Storage -->
    <li>Cozarkian.VarietyMatters.Stockpile</li>  <!-- Variety Matters Stockpile (original) -->
    <li>Mlie.VarietyMattersStockpile</li>        <!-- Variety Matters Stockpile (Continued) -->
    <li>darkside.StockpileLimit</li>             <!-- Stockpile Limit (no migration, but still double-enforces) -->
  </incompatibleWith>
</ModMetaData>
